; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the engine automatically updates the file.

config_version=5

[application]
config/name="Garden Maze Escape: Infinite Odyssey"
config/description="لعبة متاهة ثلاثية الأبعاد مع 1000 مرحلة وعوالم متعددة"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.2", "Vulkan Clustered")
config/icon="res://icon.svg"

[audio]
buses/default_bus_layout="res://default_bus_layout.tres"

[display]
window/size/viewport_width=1080
window/size/viewport_height=2460
window/size/resizable=false
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation="portrait"

[rendering]
renderer/rendering_method="forward_plus"
renderer/rendering_method.mobile="mobile"
anti_aliasing/quality/screen_space_aa=1
anti_aliasing/quality/use_taa=true
anti_aliasing/quality/msaa_3d=2
lights_and_shadows/directional_shadow/size=4096
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=3
global_illumination/sdfgi/frames_to_converge=5
global_illumination/sdfgi/frames_to_update_lights=2
environment/defaults/default_environment="res://default_env.tres"
textures/vram_compression/import_etc2_astc=true
textures/quality/astc_hdr_mode=1

[physics]
3d/physics_engine="GodotPhysics3D"

[input]
ui_accept={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194309,"physical_keycode":0,"key_label":0,"unicode":0,"echo":false,"script":null)
]
}

[layer_names]
3d_physics/layer_1="world"
3d_physics/layer_2="player"
3d_physics/layer_3="enemy"
3d_physics/layer_4="gem"
3d_physics/layer_5="exit"

[locale]
translations=PackedStringArray()
fallback="en"
